{
    "app-id": "org.kde.labplot",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.7",
    "sdk": "org.kde.Sdk",
    "command": "labplot",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=home",
        "--share=network",
        "--talk-name=org.freedesktop.Notifications",
        "--env=PYTHONPATH=/app/lib/python3.12/site-packages"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/man",
        "*.a",
        "*.la"
    ],
    "modules": [
        {
            "name": "gsl",
            "buildsystem": "autotools",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://ftp.gnu.org/gnu/gsl/gsl-2.7.1.tar.gz",
                    "sha256": "dcb0fbd43048832b757ff9942691a8dd70026d5da0ff85601e52687f6deeb34b"
                }
            ]
        },
        {
            "name": "fftw3",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_SHARED_LIBS=ON",
                "-DENABLE_THREADS=ON",
                "-DENABLE_SSE2=ON",
                "-DENABLE_AVX=ON",
                "-DENABLE_AVX2=ON"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "http://www.fftw.org/fftw-3.3.10.tar.gz",
                    "sha256": "56c932549852cddcfafdab3820b0200c7742675be92179e59e6215b340e26467"
                }
            ]
        },
        {
            "name": "poppler",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DCMAKE_BUILD_TYPE=Release",
                "-DBUILD_SHARED_LIBS=ON",
                "-DENABLE_QT6=ON",
                "-DENABLE_QT5=OFF",
                "-DENABLE_BOOST=OFF",
                "-DENABLE_GLIB=OFF",
                "-DENABLE_GOBJECT_INTROSPECTION=OFF",
                "-DENABLE_CPP=OFF",
                "-DBUILD_GTK_TESTS=OFF",
                "-DBUILD_QT6_TESTS=OFF"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://poppler.freedesktop.org/poppler-24.02.0.tar.xz",
                    "sha256": "19187a3fdd05f33e7d604c4799c183de5ca0118640c88b370ddcf3136343222e"
                }
            ]
        },
        {
            "name": "cantor",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "config-opts": [
                "-DCMAKE_BUILD_TYPE=Release",
                "-DBUILD_TESTING=OFF",
                "-DENABLE_PYTHON=ON",
                "-DENABLE_R=OFF",
                "-DENABLE_QTFED=OFF",
                "-DENABLE_JULIA=OFF",
                "-DENABLE_LUA=OFF",
                "-DENABLE_MAXIMA=OFF",
                "-DENABLE_OCTAVE=OFF",
                "-DENABLE_SAGE=OFF",
                "-DENABLE_SCILAB=OFF",
                "-DENABLE_EMBEDDED_DOCUMENTATION=OFF"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/helloydh007/cantor.git",
                    "branch": "master"
                }
            ]
        },
        {
            "name": "labplot",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "config-opts": [
                "-DCMAKE_BUILD_TYPE=Release",
                "-DCMAKE_INSTALL_PREFIX=/app",
                "-DCMAKE_PREFIX_PATH=/app",
                "-DBUILD_TESTING=OFF",
                "-DENABLE_CANTOR=ON",
                "-DCantor_DIR=/app/lib/cmake/Cantor",
                "-DENABLE_HDF5=OFF",
                "-DENABLE_NETCDF=OFF",
                "-DENABLE_PYTHON_SDK=OFF",
                "-DENABLE_PYTHON_SCRIPTING=OFF",
                "-DENABLE_READSTAT=OFF"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/helloydh007/labplot.git",
                    "branch": "master"
                }
            ]
        }
    ]
}
